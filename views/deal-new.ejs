<div class="mb-3">
  <a href="/companies/<%= company.id %>" class="small d-block mb-1"><i class="bi bi-arrow-left"></i> <%= company.name %></a>
  <h1 class="h4 mb-0">Create Deal</h1>
  <div class="text-muted small">for <%= company.name %></div>
</div>

<div class="row">
  <div class="col-lg-7">
    <div class="card">
      <div class="card-body">
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form action="/companies/<%= company.id %>/deals" method="POST">
          <div class="mb-3">
            <label class="form-label">Deal name <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" value="<%= values.name || '' %>" required autofocus>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Stage</label>
              <select name="stage" class="form-select">
                <option value="">— Select —</option>
                <% stageChoices.forEach(opt => { %>
                  <option value="<%= opt %>" <%= values.stage === opt ? 'selected' : '' %>><%= opt %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Primary contact</label>
              <select name="primaryContactId" class="form-select">
                <option value="">— None —</option>
                <% persons.forEach(p => { %>
                  <option value="<%= p.id %>" <%= values.primaryContactId === p.id ? 'selected' : '' %>><%= p.fullName %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Amount ($)</label>
              <input type="number" step="0.01" name="amount" class="form-control" value="<%= values.amount || '' %>">
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Probability (%)</label>
              <input type="number" min="0" max="100" name="probability" class="form-control" value="<%= values.probability || '' %>">
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Close date</label>
            <input type="date" name="closeDate" class="form-control" value="<%= values.closeDate || '' %>">
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Deal</button>
            <a href="/companies/<%= company.id %>" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
