<%
  function initials(name) {
    if (!name) return '?';
    const words = name.trim().split(/\s+/);
    if (words.length === 1) return words[0].slice(0, 2).toUpperCase();
    return (words[0][0] + words[1][0]).toUpperCase();
  }
  const AVATAR_COLORS = ['avatar-blue', 'avatar-purple', 'avatar-gold', 'avatar-teal', 'avatar-pink'];
  function avatarColor(i) { return AVATAR_COLORS[i % AVATAR_COLORS.length]; }

  const statusChoices = ['Planned', 'Lead', 'Client'];
  const statusCounts = {};
  statusChoices.forEach(s => { statusCounts[s] = 0; });
  companies.forEach(c => { if (c.status && statusCounts.hasOwnProperty(c.status)) statusCounts[c.status]++; });
%>

<div class="companies-page-header">
  <h1 class="companies-page-title">Companies <span class="companies-page-count"><%= companies.length %></span></h1>
  <a href="/companies/new" class="btn-add-company"><i class="bi bi-plus-lg"></i> Add Company</a>
</div>

<div class="companies-toolbar">
  <div class="status-filter-tabs" id="statusFilterTabs">
    <button type="button" class="filter-tab active" data-status="all">All <span class="filter-tab-count"><%= companies.length %></span></button>
    <% statusChoices.forEach(s => { %>
      <button type="button" class="filter-tab" data-status="<%= s %>"><%= s %> <span class="filter-tab-count"><%= statusCounts[s] %></span></button>
    <% }) %>
  </div>
  <div class="companies-search-wrap">
    <i class="bi bi-search"></i>
    <input type="text" id="companySearch" placeholder="Search companies...">
  </div>
</div>

<div class="companies-table-card">
  <table class="companies-table" id="companiesTable">
    <thead>
      <tr>
        <th>Company</th>
        <th>Industry</th>
        <th>Status</th>
        <th>Website</th>
      </tr>
    </thead>
    <tbody>
      <% companies.forEach((c, i) => { %>
        <tr class="company-row"
          data-status="<%= c.status || '' %>"
          data-search="<%= [c.name, c.industry, c.status, c.web].filter(Boolean).join(' ').toLowerCase() %>"
          onclick="window.location='/companies/<%= c.id %>'">
          <td data-label="Company">
            <div class="company-name-cell">
              <span class="company-avatar <%= avatarColor(i) %>"><%= initials(c.name) %></span>
              <div class="company-name-block">
                <div class="company-name"><%= c.name %></div>
                <div class="company-website-sub"><%= c.web || 'No website on file' %></div>
              </div>
            </div>
          </td>
          <td data-label="Industry">
            <% if (c.industry) { %><span class="industry-tag"><%= c.industry %></span><% } else { %><span class="muted-cell">—</span><% } %>
          </td>
          <td data-label="Status">
            <% if (c.status) { %>
              <span class="badge company-status-<%= c.status.replace(/\s+/g,'') %>"><span class="status-dot"></span><%= c.status %></span>
            <% } else { %><span class="muted-cell">—</span><% } %>
          </td>
          <td data-label="Website">
            <% if (c.web) { %>
              <a href="<%= c.web %>" target="_blank" rel="noopener" class="table-link" onclick="event.stopPropagation()"><%= c.web %> <i class="bi bi-box-arrow-up-right"></i></a>
            <% } else { %><span class="muted-cell">—</span><% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  <% if (!companies.length) { %>
    <div class="companies-empty-state">No companies yet.</div>
  <% } %>
</div>

<script>
  (function () {
    const searchInput = document.getElementById('companySearch');
    const tabs = document.querySelectorAll('#statusFilterTabs .filter-tab');
    const rows = document.querySelectorAll('#companiesTable tbody tr');
    let activeStatus = 'all';

    function applyFilters() {
      const q = searchInput.value.toLowerCase();
      rows.forEach((row) => {
        const matchesStatus = activeStatus === 'all' || row.dataset.status === activeStatus;
        const matchesSearch = !q || row.dataset.search.includes(q);
        row.style.display = (matchesStatus && matchesSearch) ? '' : 'none';
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t) => t.classList.remove('active'));
        tab.classList.add('active');
        activeStatus = tab.dataset.status;
        applyFilters();
      });
    });

    searchInput.addEventListener('input', applyFilters);
  })();
</script>
