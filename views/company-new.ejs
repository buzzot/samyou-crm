<div class="mb-3">
  <a href="/companies" class="small d-block mb-1"><i class="bi bi-arrow-left"></i> All companies</a>
  <h1 class="h4 mb-0">Add Company</h1>
</div>

<div class="row">
  <div class="col-lg-7">
    <div class="card">
      <div class="card-body">
        <% if (error) { %>
          <div class="alert alert-danger"><%= error %></div>
        <% } %>

        <form action="/companies" method="POST">
          <div class="mb-3">
            <label class="form-label">Company name <span class="text-danger">*</span></label>
            <input type="text" name="name" class="form-control" value="<%= values.name || '' %>" required autofocus>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Industry</label>
              <select name="industry" class="form-select">
                <option value="">— Select —</option>
                <% industryChoices.forEach(opt => { %>
                  <option value="<%= opt %>" <%= values.industry === opt ? 'selected' : '' %>><%= opt %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Status</label>
              <select name="status" class="form-select">
                <option value="">— Select —</option>
                <% statusChoices.forEach(opt => { %>
                  <option value="<%= opt %>" <%= values.status === opt ? 'selected' : '' %>><%= opt %></option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label">Website</label>
            <input type="url" name="web" class="form-control" placeholder="https://" value="<%= values.web || '' %>">
          </div>

          <div class="mb-3">
            <label class="form-label">Billing address</label>
            <textarea name="billingAddress" class="form-control" rows="2"><%= values.billingAddress || '' %></textarea>
          </div>

          <div class="mb-3">
            <label class="form-label">Notes</label>
            <textarea name="notes" class="form-control" rows="3"><%= values.notes || '' %></textarea>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Company</button>
            <a href="/companies" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
