<%
  const formAction = company ? `/companies/${company.id}/projects` : '/projects';
  const backHref = company ? `/companies/${company.id}` : '/projects';
  const backLabel = company ? company.name : 'All projects';
  const heroSub = company
    ? `Creating a project for ${company.name}. You can refine ownership and tasks after the project is created.`
    : 'Connect a company, set the stage, and tag related products. You can refine ownership and tasks after the project is created.';
  const sortedProducts = [...products].sort((a, b) => (a.name || '').localeCompare(b.name || ''));
%>

<div class="pnew-page">
  <a href="<%= backHref %>" class="pnew-back-link"><i class="bi bi-arrow-left"></i> <%= backLabel %></a>

  <div class="pnew-badge"><i class="bi bi-folder-plus"></i> New project</div>

  <h1 class="pnew-hero">Create a <em>project</em></h1>
  <p class="pnew-hero-sub"><%= heroSub %></p>

  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <form action="<%= formAction %>" method="POST" id="projectNewForm" enctype="multipart/form-data">
    <div class="pnew-grid">
      <div class="pnew-main">

        <div class="pnew-card">
          <h2 class="pnew-card-title">Identity</h2>
          <p class="pnew-card-sub">What this project is and who it's for.</p>

          <label class="pnew-field-label" for="pnewName">Project name <span class="pnew-required">*</span></label>
          <input type="text" name="name" id="pnewName" class="pnew-input" placeholder="e.g. Rheem Heat Pump — Phase 2" value="<%= values.name || '' %>" required autofocus>
          <div class="pnew-help">Use a short, recognisable label — you can rename later.</div>

          <% if (company) { %>
            <label class="pnew-field-label mt-3"><i class="bi bi-building"></i> Company</label>
            <div class="pnew-static-field"><%= company.name %></div>
          <% } else { %>
            <label class="pnew-field-label mt-3" for="pnewCompany"><i class="bi bi-building"></i> Company</label>
            <select name="companyId" id="pnewCompany" class="pnew-select">
              <option value="">— None —</option>
              <% companies.forEach(c => { %>
                <option value="<%= c.id %>" <%= values.companyId === c.id ? 'selected' : '' %>><%= c.name %></option>
              <% }) %>
            </select>
          <% } %>
        </div>

        <div class="pnew-card">
          <h2 class="pnew-card-title">Classification</h2>
          <p class="pnew-card-sub">Where it sits in your pipeline.</p>

          <div class="pnew-classification-row">
            <div>
              <label class="pnew-field-label"><i class="bi bi-activity"></i> Status</label>
              <input type="hidden" name="status" id="pnewStatusInput" value="<%= values.status || '' %>">
              <div class="pnew-status-chips" id="pnewStatusChips">
                <% statusChoices.forEach(opt => { %>
                  <button type="button" class="pnew-status-chip <%= values.status === opt ? 'active' : '' %>" data-status="<%= opt %>"><span class="pnew-chip-dot"></span><%= opt %></button>
                <% }) %>
              </div>
            </div>
            <div>
              <label class="pnew-field-label" for="pnewCategory"><i class="bi bi-tag"></i> Category</label>
              <select name="category" id="pnewCategory" class="pnew-select">
                <option value="">— Select —</option>
                <% categoryChoices.forEach(opt => { %>
                  <option value="<%= opt %>" <%= values.category === opt ? 'selected' : '' %>><%= opt %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </div>

        <div class="pnew-card">
          <div class="pnew-products-header">
            <div>
              <h2 class="pnew-card-title">Related products</h2>
              <p class="pnew-card-sub">Tag existing products — or create a new one if this is a development project.</p>
            </div>
            <div class="pnew-products-header-actions">
              <span class="pnew-product-count" id="pnewProductCount">0 selected</span>
              <button type="button" class="pnew-btn-new-product" data-bs-toggle="modal" data-bs-target="#newProductModal"><i class="bi bi-plus-lg"></i> New product</button>
            </div>
          </div>

          <div class="pnew-search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" id="pnewProductSearch" placeholder="Search products by name or category...">
          </div>

          <div class="pnew-product-list" id="pnewProductList">
            <% if (!sortedProducts.length) { %>
              <div class="pnew-product-empty">No products yet.</div>
            <% } %>
            <% sortedProducts.forEach(p => { %>
              <label class="pnew-product-row" data-search="<%= [p.name, p.category].filter(Boolean).join(' ').toLowerCase() %>">
                <input type="checkbox" name="productIds" value="<%= p.id %>" class="pnew-product-checkbox">
                <span class="pnew-product-name"><%= p.name %></span>
                <% if (p.category) { %><span class="pnew-product-sub"><%= p.category %></span><% } %>
              </label>
            <% }) %>
          </div>
        </div>

        <div class="pnew-card">
          <h2 class="pnew-card-title">Timeline</h2>
          <p class="pnew-card-sub">Optional — leave blank if not yet scheduled.</p>

          <div class="pnew-timeline-grid">
            <div>
              <label class="pnew-field-label" for="pnewStartDate"><i class="bi bi-calendar3"></i> Start date</label>
              <input type="date" name="startDate" id="pnewStartDate" class="pnew-input" value="<%= values.startDate || '' %>">
            </div>
            <div>
              <label class="pnew-field-label" for="pnewEndDate"><i class="bi bi-calendar3"></i> End date</label>
              <input type="date" name="endDate" id="pnewEndDate" class="pnew-input" value="<%= values.endDate || '' %>">
            </div>
          </div>
        </div>

        <div class="pnew-card">
          <div class="pnew-description-header">
            <h2 class="pnew-card-title">Description</h2>
            <span class="pnew-char-counter" id="pnewCharCounter">0/500</span>
          </div>
          <p class="pnew-card-sub">Context for your team. Markdown not required.</p>
          <textarea name="description" id="pnewDescription" class="pnew-textarea" rows="4" maxlength="500" placeholder="Goals, scope, key contacts, anything the team should know..."><%= values.description || '' %></textarea>
        </div>

        <div class="pnew-card">
          <h2 class="pnew-card-title">Attachments</h2>
          <p class="pnew-card-sub">Briefs, datasheets, or reference images for this project.</p>

          <label class="pnew-dropzone" id="pnewDropzone" for="pnewFileInput">
            <i class="bi bi-cloud-arrow-up"></i>
            <div class="pnew-dropzone-text">Drop files here, or <span class="pnew-dropzone-browse">browse</span></div>
            <div class="pnew-dropzone-help">Up to 25MB per file &middot; images, PDFs, docs, spreadsheets</div>
          </label>
          <input type="file" name="attachments" id="pnewFileInput" class="pnew-file-input" multiple>

          <div class="pnew-file-list" id="pnewFileList"></div>
        </div>

      </div>

      <div class="pnew-aside">
        <div class="pnew-summary-card">
          <div class="pnew-summary-title">Summary</div>
          <div class="pnew-summary-row"><span>Name</span><span id="pnewSummaryName">Untitled</span></div>
          <div class="pnew-summary-row"><span>Company</span><span id="pnewSummaryCompany">—</span></div>
          <div class="pnew-summary-row"><span>Status</span><span id="pnewSummaryStatus">—</span></div>
          <div class="pnew-summary-row"><span>Category</span><span id="pnewSummaryCategory">—</span></div>
          <div class="pnew-summary-row"><span>Products</span><span id="pnewSummaryProducts">—</span></div>
          <div class="pnew-summary-row"><span>Window</span><span id="pnewSummaryWindow">—</span></div>
          <div class="pnew-summary-row"><span>Files</span><span id="pnewSummaryFiles">—</span></div>
        </div>

        <div class="pnew-tip-card">
          <i class="bi bi-file-earmark-text"></i>
          <div class="pnew-tip-title">Tip</div>
          <div class="pnew-tip-text">Projects without a status default to the first stage in your pipeline. You can always update classification from the project detail view.</div>
        </div>
      </div>
    </div>

    <div class="pnew-footer-bar">
      <span class="pnew-footer-msg" id="pnewFooterMsg">Project name is required to continue.</span>
      <div class="pnew-footer-actions">
        <a href="<%= backHref %>" class="pnew-btn-cancel">Cancel</a>
        <button type="submit" class="pnew-btn-save" id="pnewSaveBtn" disabled><i class="bi bi-check-lg"></i> Save project</button>
      </div>
    </div>
  </form>

  <div class="modal fade" id="newProductModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-box-seam me-1"></i> New product</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="alert alert-danger d-none" id="npError"></div>
          <label class="pnew-field-label" for="npName">Product name <span class="pnew-required">*</span></label>
          <input type="text" id="npName" class="pnew-input" placeholder="e.g. DC Inverter Driver — 5HP">
          <label class="pnew-field-label mt-3" for="npCategory"><i class="bi bi-tag"></i> Category</label>
          <select id="npCategory" class="pnew-select">
            <option value="">— Select —</option>
            <% (typeof productCategoryChoices !== 'undefined' ? productCategoryChoices : []).forEach(opt => { %>
              <option value="<%= opt %>"><%= opt %></option>
            <% }) %>
          </select>
        </div>
        <div class="modal-footer">
          <button type="button" class="pnew-btn-cancel" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="pnew-btn-save" id="npCreateBtn"><i class="bi bi-check-lg"></i> Create product</button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const nameInput = document.getElementById('pnewName');
    const companySelect = document.getElementById('pnewCompany');
    const statusChips = document.querySelectorAll('#pnewStatusChips .pnew-status-chip');
    const statusInput = document.getElementById('pnewStatusInput');
    const categorySelect = document.getElementById('pnewCategory');
    const productSearch = document.getElementById('pnewProductSearch');
    const productList = document.getElementById('pnewProductList');
    const productCount = document.getElementById('pnewProductCount');
    const startDate = document.getElementById('pnewStartDate');
    const endDate = document.getElementById('pnewEndDate');
    const description = document.getElementById('pnewDescription');
    const charCounter = document.getElementById('pnewCharCounter');
    const saveBtn = document.getElementById('pnewSaveBtn');
    const footerMsg = document.getElementById('pnewFooterMsg');

    const summaryName = document.getElementById('pnewSummaryName');
    const summaryCompany = document.getElementById('pnewSummaryCompany');
    const summaryStatus = document.getElementById('pnewSummaryStatus');
    const summaryCategory = document.getElementById('pnewSummaryCategory');
    const summaryProducts = document.getElementById('pnewSummaryProducts');
    const summaryWindow = document.getElementById('pnewSummaryWindow');
    const summaryFiles = document.getElementById('pnewSummaryFiles');

    const fileInput = document.getElementById('pnewFileInput');
    const dropzone = document.getElementById('pnewDropzone');
    const fileList = document.getElementById('pnewFileList');

    function formatBytes(bytes) {
      if (bytes < 1024) return `${bytes} B`;
      if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
      return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
    }

    function renderFileList() {
      const files = Array.from(fileInput.files || []);
      fileList.innerHTML = '';
      files.forEach((file, idx) => {
        const row = document.createElement('div');
        row.className = 'pnew-file-row';
        row.innerHTML = `
          <i class="bi bi-file-earmark"></i>
          <span class="pnew-file-name">${file.name}</span>
          <span class="pnew-file-size">${formatBytes(file.size)}</span>
          <button type="button" class="pnew-file-remove" data-idx="${idx}" aria-label="Remove"><i class="bi bi-x"></i></button>
        `;
        fileList.appendChild(row);
      });

      fileList.querySelectorAll('.pnew-file-remove').forEach((btn) => {
        btn.addEventListener('click', () => {
          const idx = Number(btn.dataset.idx);
          const dt = new DataTransfer();
          Array.from(fileInput.files).forEach((f, i) => { if (i !== idx) dt.items.add(f); });
          fileInput.files = dt.files;
          renderFileList();
          updateSummary();
        });
      });

      summaryFiles.textContent = files.length ? `${files.length} file${files.length === 1 ? '' : 's'}` : '—';
    }

    fileInput.addEventListener('change', renderFileList);

    ['dragover', 'dragenter'].forEach((evt) => {
      dropzone.addEventListener(evt, (e) => {
        e.preventDefault();
        dropzone.classList.add('dragover');
      });
    });
    ['dragleave', 'dragend'].forEach((evt) => {
      dropzone.addEventListener(evt, () => dropzone.classList.remove('dragover'));
    });
    dropzone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('dragover');
      const incoming = Array.from(e.dataTransfer.files || []);
      if (!incoming.length) return;
      const dt = new DataTransfer();
      Array.from(fileInput.files || []).forEach((f) => dt.items.add(f));
      incoming.forEach((f) => dt.items.add(f));
      fileInput.files = dt.files;
      renderFileList();
    });

    function formatDate(value) {
      if (!value) return null;
      const d = new Date(value + 'T00:00:00');
      if (isNaN(d.getTime())) return null;
      return d.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
    }

    function updateSummary() {
      summaryName.textContent = nameInput.value.trim() || 'Untitled';

      if (companySelect) {
        const opt = companySelect.options[companySelect.selectedIndex];
        summaryCompany.textContent = (opt && opt.value) ? opt.textContent : '—';
      }

      summaryStatus.textContent = statusInput.value || '—';
      summaryCategory.textContent = categorySelect.value || '—';

      const checked = Array.from(document.querySelectorAll('#pnewProductList input[type=checkbox]:checked'));
      productCount.textContent = `${checked.length} selected`;
      if (!checked.length) {
        summaryProducts.textContent = '—';
      } else {
        const firstName = checked[0].closest('.pnew-product-row').querySelector('.pnew-product-name').textContent;
        summaryProducts.textContent = checked.length === 1 ? firstName : `${firstName} +${checked.length - 1} more`;
      }

      const startLabel = formatDate(startDate.value);
      const endLabel = formatDate(endDate.value);
      if (startLabel && endLabel) summaryWindow.textContent = `${startLabel} – ${endLabel}`;
      else if (startLabel) summaryWindow.textContent = `From ${startLabel}`;
      else if (endLabel) summaryWindow.textContent = `Until ${endLabel}`;
      else summaryWindow.textContent = '—';
    }

    function updateSaveState() {
      const ready = !!nameInput.value.trim();
      saveBtn.disabled = !ready;
      footerMsg.textContent = ready ? '' : 'Project name is required to continue.';
    }

    nameInput.addEventListener('input', () => { updateSummary(); updateSaveState(); });
    if (companySelect) companySelect.addEventListener('change', updateSummary);
    categorySelect.addEventListener('change', updateSummary);
    startDate.addEventListener('change', updateSummary);
    endDate.addEventListener('change', updateSummary);

    statusChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const isActive = chip.classList.contains('active');
        statusChips.forEach((c) => c.classList.remove('active'));
        if (!isActive) {
          chip.classList.add('active');
          statusInput.value = chip.dataset.status;
        } else {
          statusInput.value = '';
        }
        updateSummary();
      });
    });

    productSearch.addEventListener('input', () => {
      const q = productSearch.value.toLowerCase();
      productList.querySelectorAll('.pnew-product-row').forEach((row) => {
        row.style.display = (!q || row.dataset.search.includes(q)) ? '' : 'none';
      });
    });

    // Delegated so dynamically-added rows (from "+ New product") work too.
    productList.addEventListener('change', (e) => {
      if (e.target.matches('input[type=checkbox]')) updateSummary();
    });

    // --- "+ New product" modal -------------------------------------------
    const newProductModalEl = document.getElementById('newProductModal');
    const npName = document.getElementById('npName');
    const npCategory = document.getElementById('npCategory');
    const npError = document.getElementById('npError');
    const npCreateBtn = document.getElementById('npCreateBtn');
    const newProductModal = window.bootstrap ? new bootstrap.Modal(newProductModalEl) : null;

    function addProductRow(product) {
      const empty = productList.querySelector('.pnew-product-empty');
      if (empty) empty.remove();

      const label = document.createElement('label');
      label.className = 'pnew-product-row';
      label.dataset.search = [product.name, product.category].filter(Boolean).join(' ').toLowerCase();
      label.innerHTML = `
        <input type="checkbox" name="productIds" value="${product.id}" class="pnew-product-checkbox" checked>
        <span class="pnew-product-name"></span>
        ${product.category ? '<span class="pnew-product-sub"></span>' : ''}
      `;
      label.querySelector('.pnew-product-name').textContent = product.name;
      if (product.category) label.querySelector('.pnew-product-sub').textContent = product.category;
      productList.prepend(label);
      updateSummary();
    }

    newProductModalEl.addEventListener('shown.bs.modal', () => {
      npName.value = '';
      npCategory.value = '';
      npError.classList.add('d-none');
      npName.focus();
    });

    npCreateBtn.addEventListener('click', async () => {
      const name = npName.value.trim();
      if (!name) {
        npError.textContent = 'Product name is required.';
        npError.classList.remove('d-none');
        return;
      }
      npCreateBtn.disabled = true;
      try {
        const res = await fetch('/api/products', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, category: npCategory.value || null })
        });
        const data = await res.json();
        if (!data.ok) throw new Error(data.error || 'Could not create product.');
        addProductRow(data.product);
        if (newProductModal) newProductModal.hide();
      } catch (err) {
        npError.textContent = err.message;
        npError.classList.remove('d-none');
      } finally {
        npCreateBtn.disabled = false;
      }
    });

    description.addEventListener('input', () => {
      charCounter.textContent = `${description.value.length}/500`;
    });

    updateSummary();
    updateSaveState();
    renderFileList();
    charCounter.textContent = `${description.value.length}/500`;
  })();
</script>
