<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
  <div>
    <% if (deal.company) { %>
      <a href="/companies/<%= deal.company.id %>" class="small d-block mb-1"><i class="bi bi-arrow-left"></i> <%= deal.company.name %></a>
    <% } %>
    <h1 class="h3 mb-0"><%= deal.name %></h1>
    <div class="text-muted">
      <% if (deal.stage) { %><span class="badge stage-badge stage-<%= (deal.stage||'').replace(/\s+/g,'') %>"><%= deal.stage %></span><% } %>
    </div>
  </div>
</div>

<% if (error) { %>
  <div class="alert alert-danger"><%= error %></div>
<% } %>

<div class="row g-3">
  <div class="col-lg-4">
    <div class="card mb-3">
      <div class="card-header fw-semibold"><i class="bi bi-building me-1"></i>Company</div>
      <div class="card-body">
        <% if (deal.company) { %>
          <a href="/companies/<%= deal.company.id %>"><%= deal.company.name %></a>
        <% } else { %>
          <span class="text-muted">No related company.</span>
        <% } %>
      </div>
    </div>

    <div class="card mb-3">
      <div class="card-header fw-semibold"><i class="bi bi-person me-1"></i>Primary contact</div>
      <div class="card-body">
        <% if (deal.primaryContact) { %>
          <div class="fw-semibold"><%= deal.primaryContact.fullName %></div>
          <% if (deal.primaryContact.email) { %><div class="small"><a href="mailto:<%= deal.primaryContact.email %>"><%= deal.primaryContact.email %></a></div><% } %>
          <% if (deal.primaryContact.phone) { %><div class="small text-muted"><%= deal.primaryContact.phone %></div><% } %>
        <% } else { %>
          <span class="text-muted">No primary contact.</span>
        <% } %>
      </div>
    </div>

    <div class="card">
      <div class="card-header fw-semibold"><i class="bi bi-currency-dollar me-1"></i>Deal details</div>
      <ul class="list-group list-group-flush">
        <li class="list-group-item d-flex justify-content-between">
          <span class="text-muted">Amount</span>
          <span class="fw-semibold">$<%= (deal.amount || 0).toLocaleString() %></span>
        </li>
        <li class="list-group-item d-flex justify-content-between">
          <span class="text-muted">Probability</span>
          <span><%= deal.probability ? Math.round(deal.probability * 100) + '%' : '—' %></span>
        </li>
        <li class="list-group-item d-flex justify-content-between">
          <span class="text-muted">Close date</span>
          <span><%= deal.closeDate || '—' %></span>
        </li>
        <li class="list-group-item d-flex justify-content-between">
          <span class="text-muted">Created</span>
          <span><%= deal.createdDate || '—' %></span>
        </li>
      </ul>
    </div>
  </div>

  <div class="col-lg-8">
    <div class="card mb-3">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold"><i class="bi bi-diagram-3 me-1"></i>Projects (<%= deal.projects.length %>)</span>
        <div class="d-flex gap-2">
          <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="collapse" data-bs-target="#linkProjectsForm">Link existing</button>
          <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="collapse" data-bs-target="#newProjectForm"><i class="bi bi-plus-lg me-1"></i>New Project</button>
        </div>
      </div>

      <div class="collapse" id="linkProjectsForm">
        <div class="card-body border-bottom">
          <form action="/deals/<%= deal.id %>/links" method="POST">
            <% (deal.productIds||[]).forEach(pid => { %><input type="hidden" name="productIds" value="<%= pid %>"><% }) %>
            <div class="mb-2">
              <label class="form-label small">Select project(s) to link</label>
              <select name="projectIds" class="form-select" multiple size="5">
                <% allProjects.forEach(p => { %>
                  <option value="<%= p.id %>" <%= (deal.projectIds||[]).includes(p.id) ? 'selected' : '' %>><%= p.name %></option>
                <% }) %>
              </select>
              <div class="form-text">Hold Ctrl/Cmd to select more than one. This replaces the current link list.</div>
            </div>
            <button type="submit" class="btn btn-sm btn-primary">Save Links</button>
          </form>
        </div>
      </div>

      <div class="collapse" id="newProjectForm">
        <div class="card-body border-bottom">
          <form action="/deals/<%= deal.id %>/projects" method="POST">
            <div class="mb-2">
              <label class="form-label small">Project name <span class="text-danger">*</span></label>
              <input type="text" name="name" class="form-control form-control-sm" required>
            </div>
            <div class="row">
              <div class="col-md-6 mb-2">
                <label class="form-label small">Status</label>
                <select name="status" class="form-select form-select-sm">
                  <option value="">— Select —</option>
                  <% statusChoices.forEach(opt => { %><option value="<%= opt %>"><%= opt %></option><% }) %>
                </select>
              </div>
              <div class="col-md-6 mb-2">
                <label class="form-label small">Category</label>
                <select name="category" class="form-select form-select-sm">
                  <option value="">— Select —</option>
                  <% categoryChoices.forEach(opt => { %><option value="<%= opt %>"><%= opt %></option><% }) %>
                </select>
              </div>
            </div>
            <button type="submit" class="btn btn-sm btn-primary">Create &amp; Link Project</button>
          </form>
        </div>
      </div>

      <ul class="list-group list-group-flush">
        <% if (!deal.projects.length) { %>
          <li class="list-group-item text-muted">No projects linked yet.</li>
        <% } %>
        <% deal.projects.forEach(p => { %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <a href="/projects/<%= p.id %>" class="fw-semibold table-link"><%= p.name %></a>
            <% if (p.status) { %><span class="badge project-status-<%= p.status.replace(/\s+/g,'') %>"><%= p.status %></span><% } %>
          </li>
        <% }) %>
      </ul>
    </div>

    <div class="card mb-3">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold"><i class="bi bi-box-seam me-1"></i>Products (<%= deal.products.length %>)</span>
        <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="collapse" data-bs-target="#linkProductsForm">Edit</button>
      </div>

      <div class="collapse" id="linkProductsForm">
        <div class="card-body border-bottom">
          <form action="/deals/<%= deal.id %>/links" method="POST">
            <% (deal.projectIds||[]).forEach(pid => { %><input type="hidden" name="projectIds" value="<%= pid %>"><% }) %>
            <div class="mb-2">
              <label class="form-label small">Select product(s) — optional, none by default</label>
              <select name="productIds" class="form-select" multiple size="5">
                <% allProducts.forEach(p => { %>
                  <option value="<%= p.id %>" <%= (deal.productIds||[]).includes(p.id) ? 'selected' : '' %>><%= p.name %></option>
                <% }) %>
              </select>
            </div>
            <button type="submit" class="btn btn-sm btn-primary">Save Products</button>
          </form>
        </div>
      </div>

      <ul class="list-group list-group-flush">
        <% if (!deal.products.length) { %>
          <li class="list-group-item text-muted">No product linked.</li>
        <% } %>
        <% deal.products.forEach(p => { %>
          <li class="list-group-item"><%= p.name %></li>
        <% }) %>
      </ul>
    </div>

    <div class="card mb-3">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold"><i class="bi bi-clock-history me-1"></i>Activity history (<%= deal.activities.length %>)</span>
        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="collapse" data-bs-target="#newActivityForm"><i class="bi bi-plus-lg me-1"></i>New Activity</button>
      </div>

      <div class="collapse" id="newActivityForm">
        <div class="card-body border-bottom">
          <form action="/deals/<%= deal.id %>/activities" method="POST">
            <div class="mb-2">
              <label class="form-label small">Activity name <span class="text-danger">*</span></label>
              <input type="text" name="name" class="form-control form-control-sm" required>
            </div>
            <div class="row">
              <div class="col-md-6 mb-2">
                <label class="form-label small">Type</label>
                <select name="type" class="form-select form-select-sm">
                  <option value="">— Select —</option>
                  <% activityTypeChoices.forEach(opt => { %><option value="<%= opt %>"><%= opt %></option><% }) %>
                </select>
              </div>
              <div class="col-md-6 mb-2">
                <label class="form-label small">Date</label>
                <input type="date" name="date" class="form-control form-control-sm">
              </div>
            </div>
            <div class="mb-2">
              <label class="form-label small">Details</label>
              <textarea name="details" class="form-control form-control-sm" rows="2"></textarea>
            </div>
            <button type="submit" class="btn btn-sm btn-primary">Log Activity</button>
          </form>
        </div>
      </div>

      <div class="card-body">
        <% if (!deal.activities.length) { %>
          <p class="text-muted mb-0">No activity logged yet — calls, emails, meetings, and documents for this deal will show up here.</p>
        <% } else { %>
          <div class="activity-timeline">
            <% deal.activities.forEach(a => { %>
              <div class="timeline-item">
                <span class="timeline-icon tl-blue">
                  <% if (a.type === 'Call') { %><i class="bi bi-telephone"></i>
                  <% } else if (a.type === 'Email') { %><i class="bi bi-envelope"></i>
                  <% } else if (a.type === 'LinkedIn') { %><i class="bi bi-linkedin"></i>
                  <% } else if (a.type === 'Meeting' || a.type === 'Demo') { %><i class="bi bi-camera-video"></i>
                  <% } else { %><i class="bi bi-clock-history"></i>
                  <% } %>
                </span>
                <div class="timeline-body">
                  <a href="/activities/<%= a.id %>" class="fw-semibold table-link"><%= a.name || '(untitled)' %></a>
                  <div class="small text-muted">
                    <%= a.type || '' %><% if (a.date) { %> &middot; <%= a.date %><% } %>
                  </div>
                  <% if (a.emailSubject) { %><div class="small text-muted"><i class="bi bi-envelope"></i> <%= a.emailSubject %></div><% } %>
                  <% if (a.files && a.files.length) { %><div class="small text-muted"><i class="bi bi-paperclip"></i> <%= a.files.length %> file(s)</div><% } %>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>

    <%
      function noteTimeAgo(dateStr) {
        if (!dateStr) return '';
        const then = new Date(dateStr);
        if (isNaN(then.getTime())) return dateStr;
        const sec = Math.floor((Date.now() - then.getTime()) / 1000);
        if (sec < 60) return 'just now';
        const min = Math.floor(sec / 60);
        if (min < 60) return min + 'm ago';
        const hr = Math.floor(min / 60);
        if (hr < 24) return hr + 'h ago';
        const day = Math.floor(hr / 24);
        if (day < 30) return day + 'd ago';
        return then.toLocaleDateString();
      }
      const noteAvatarClasses = ['note-avatar-blue', 'note-avatar-purple', 'note-avatar-gray'];
      const youInitial = ((typeof currentUser !== 'undefined' && currentUser && (currentUser.name || currentUser.email)) || '?').trim().charAt(0).toUpperCase();
      const orderedComments = deal.comments.slice().reverse();
    %>
    <div class="card">
      <div class="card-header fw-semibold"><i class="bi bi-chat-left-text me-1"></i>Notes (<%= deal.comments.length %>)</div>

      <div class="card-body note-composer">
        <form action="/deals/<%= deal.id %>/comments" method="POST">
          <div class="note-compose-box">
            <div class="d-flex gap-2">
              <span class="note-avatar note-avatar-you"><%= youInitial %></span>
              <textarea name="comment" class="note-textarea" rows="2" placeholder="Add a note..." required></textarea>
            </div>
            <div class="note-compose-footer">
              <div class="note-link-field">
                <i class="bi bi-link-45deg"></i>
                <input type="url" name="link" class="note-link-input-inline" placeholder="Optional link (e.g. to a file)">
              </div>
              <button type="submit" class="note-post-btn"><i class="bi bi-send-fill me-1"></i>Send</button>
            </div>
          </div>
        </form>
      </div>

      <div class="note-thread">
        <% if (!deal.comments.length) { %>
          <p class="text-muted mb-0">No notes yet.</p>
        <% } %>
        <% orderedComments.forEach((c, i) => { %>
          <% const initial = (c.author || '?').trim().charAt(0).toUpperCase(); %>
          <div class="note-item">
            <div class="note-item-head">
              <span class="note-avatar <%= noteAvatarClasses[i % noteAvatarClasses.length] %>"><%= initial %></span>
              <span class="fw-semibold note-author"><%= c.author || 'Someone' %></span>
              <span class="text-muted small note-item-time"><%= noteTimeAgo(c.postedAt) %></span>
            </div>
            <div class="note-bubble">
              <div class="note-text"><%= c.comment %></div>
              <% if (c.link) { %>
                <a href="<%= c.link %>" target="_blank" rel="noopener" class="note-link-chip"><i class="bi bi-link-45deg"></i><%= c.link %></a>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>
