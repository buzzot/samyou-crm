# Airtable
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appcE3X4eDSNXwOQl

# App auth — "Sign in with Airtable" (OAuth2 + PKCE). Register an OAuth
# integration at https://airtable.com/create/oauth and put its Client ID
# and Client Secret here. Redirect URI must be APP_BASE_URL + /auth/airtable/callback.
AIRTABLE_OAUTH_CLIENT_ID=your-oauth-client-id
AIRTABLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
APP_BASE_URL=http://localhost:3000

# This email is always granted the Admin role, regardless of their
# permission level on the Airtable base.
ADMIN_EMAIL=buzzardontree@gmail.com

# Session
SESSION_SECRET=change-this-to-a-long-random-string

# Server
PORT=3000

# IMAP (for "Find related emails" on activities)
IMAP_HOST=imap.qiye.aliyun.com
IMAP_PORT=993
IMAP_USER=marsel@samyouusa.com
IMAP_PASSWORD=your-mailbox-password-or-app-password

# Resend (transactional email — used to notify a user when they are
# assigned a task). Get an API key at https://resend.com/api-keys and a
# verified sender at https://resend.com/domains.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=notifications@yourdomain.com
